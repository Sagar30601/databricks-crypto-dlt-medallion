        "ORDER BY mcap_rank ASC"
      ]
    },
    {
      "name": "0b777f59",
      "displayName": "monthly_winner",
      "queryLines": [
        "SELECT\r\n",
        "    month,\r\n",
        "    CASE\r\n",
        "        WHEN coin_id IN ('btc', 'bitcoin')           THEN 'bitcoin'\r\n",
        "        WHEN coin_id IN ('bnb', 'binancecoin')       THEN 'binancecoin'\r\n",
        "        WHEN coin_id IN ('eth', 'ethereum')           THEN 'ethereum'\r\n",
        "        WHEN coin_id IN ('sol', 'solana')             THEN 'solana'\r\n",
        "        WHEN coin_id IN ('ada', 'cardano')            THEN 'cardano'\r\n",
        "        WHEN coin_id IN ('xrp', 'ripple')             THEN 'ripple'\r\n",
        "        WHEN coin_id IN ('doge', 'dogecoin')          THEN 'dogecoin'\r\n",
        "        WHEN coin_id IN ('dot', 'polkadot')           THEN 'polkadot'\r\n",
        "        WHEN coin_id IN ('link', 'chainlink')         THEN 'chainlink'\r\n",
        "        WHEN coin_id IN ('avax', 'avalanche-2')       THEN 'avalanche'\r\n",
        "        ELSE coin_id\r\n",
        "    END AS coin_id,\r\n",
        "    monthly_return_pct\r\n",
        "FROM crypto_analytics.gold.top_performers_monthly\r\n",
        "WHERE rank = 1\r\n",
        "  AND month >= '2025-01'\r\n",
        "ORDER BY month DESC"
      ]
    },
    {
      "name": "61b66255",
      "displayName": "daily_return_heatmap",
      "queryLines": [
        "SELECT\r\n",
        "    CASE\r\n",
        "        WHEN coin_id IN ('btc', 'bitcoin')           THEN 'bitcoin'\r\n",
        "        WHEN coin_id IN ('bnb', 'binancecoin')       THEN 'binancecoin'\r\n",
        "        WHEN coin_id IN ('eth', 'ethereum')           THEN 'ethereum'\r\n",
        "        WHEN coin_id IN ('sol', 'solana')             THEN 'solana'\r\n",
        "        WHEN coin_id IN ('ada', 'cardano')            THEN 'cardano'\r\n",
        "        WHEN coin_id IN ('xrp', 'ripple')             THEN 'ripple'\r\n",
        "        WHEN coin_id IN ('doge', 'dogecoin')          THEN 'dogecoin'\r\n",
        "        WHEN coin_id IN ('dot', 'polkadot')           THEN 'polkadot'\r\n",
        "        WHEN coin_id IN ('link', 'chainlink')         THEN 'chainlink'\r\n",
        "        WHEN coin_id IN ('avax', 'avalanche-2')       THEN 'avalanche'\r\n",
        "        ELSE coin_id\r\n",
        "    END AS coin_id,\r\n",
        "    DATE_FORMAT(trade_date, 'yyyy-MM') AS month,\r\n",
        "    ROUND(AVG(daily_return_pct), 2)    AS avg_monthly_return\r\n",
        "FROM crypto_analytics.gold.daily_market_summary\r\n",
        "WHERE trade_date >= '2025-01-01'\r\n",
        "GROUP BY coin_id, DATE_FORMAT(trade_date, 'yyyy-MM')\r\n",
        "ORDER BY coin_id, month"
      ]
    },
    {
      "name": "2db6c1ff",
      "displayName": "pipeline_summary",
      "queryLines": [
        "WITH cleaned AS (\r\n",
        "    SELECT\r\n",
        "        CASE\r\n",
        "            WHEN coin_id IN ('btc', 'bitcoin')       THEN 'bitcoin'\r\n",
        "            WHEN coin_id IN ('bnb', 'binancecoin')   THEN 'binancecoin'\r\n",
        "            WHEN coin_id IN ('eth', 'ethereum')       THEN 'ethereum'\r\n",
        "            WHEN coin_id IN ('sol', 'solana')         THEN 'solana'\r\n",
        "            WHEN coin_id IN ('ada', 'cardano')        THEN 'cardano'\r\n",
        "            WHEN coin_id IN ('xrp', 'ripple')         THEN 'ripple'\r\n",
        "            WHEN coin_id IN ('doge', 'dogecoin')      THEN 'dogecoin'\r\n",
        "            WHEN coin_id IN ('dot', 'polkadot')       THEN 'polkadot'\r\n",
        "            WHEN coin_id IN ('link', 'chainlink')     THEN 'chainlink'\r\n",
        "            WHEN coin_id IN ('avax', 'avalanche-2')   THEN 'avalanche'\r\n",
        "            ELSE coin_id\r\n",
        "        END AS coin_id,\r\n",
        "        trade_date\r\n",
        "    FROM crypto_analytics.gold.daily_market_summary\r\n",
        ")\r\n",
        "SELECT 'Total Coins'        AS metric, COUNT(DISTINCT coin_id)  AS value FROM cleaned\r\n",
        "UNION ALL\r\n",
        "SELECT 'Total Trading Days' AS metric, COUNT(DISTINCT trade_date) AS value FROM cleaned\r\n",
        "UNION ALL\r\n",
        "SELECT 'Total Records'      AS metric, COUNT(*)                 AS value FROM cleaned"
      ]
    }
